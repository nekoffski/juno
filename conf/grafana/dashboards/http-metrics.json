      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(rate(juno_requests_total{code=~\"5..\"}[$__rate_interval])) / sum(rate(juno_requests_total[$__rate_interval]))",
          "legendFormat": "5xx error rate",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(rate(juno_requests_total{code=~\"4..\"}[$__rate_interval])) / sum(rate(juno_requests_total[$__rate_interval]))",
          "legendFormat": "4xx error rate",
          "refId": "B"
        }
      ],
      "title": "Error Rate",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
